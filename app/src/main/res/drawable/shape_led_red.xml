<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:padding="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/led_red" />
        </shape>
    </item>
    <item android:padding="2dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="2dp"
                android:color="@color/led_red_glow" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="@color/led_red_darkglow" />
        </shape>
    </item>
</layer-list>